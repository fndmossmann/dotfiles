#!/usr/bin/env bash
# ==============================================================================
# Script: fortinet_lifecycle.sh
# Descrição: Consulta o feed RSS oficial da Fortinet para obter e formatar as
#            datas de EOO, LSED e EOS de equipamentos, com alertas visuais.
# Autor: Desenvolvido por Gemini 3.1 Pro (Google), idealizado e estruturado sob
#        orientações e prompts de fndmossmann.
# Data de Criação: 17 de Março de 2026
#
# CHANGELOG:
# v1.2: Implementada lógica de cores inteligente: Vermelho (Expirado), 
#       Laranja (Próximo/2 meses) e Verde (OK) baseada na data atual do sistema.
# v1.1: Adicionado tratamento para entidades HTML (&lt;br/&gt;) e limpeza de
#       strings para garantir a quebra de linha correta na descrição.
# v1.0: Versão inicial. Consumo do feed RSS, busca por modelo/substring e
#       formatação básica de saída em bloco.
# ==============================================================================

# Cores para o Bash
COR_ERRO="\033[1;31m"
COR_INFO="\033[1;34m"
COR_DESTAQUE="\033[1;33m"
RESET="\033[0m"

# Verifica se o usuário informou algum parâmetro
if [ -z "$1" ]; then
    echo -e "${COR_ERRO}Uso: $0 <modelo>${RESET}"
    echo "Exemplo: $0 Fortigate-200F"
    echo "Exemplo: $0 200F"
    exit 1
fi

MODELO="$1"
URL="https://support.fortinet.com/rss/Hardware.xml"

echo -e "${COR_INFO}Consultando o banco de dados da Fortinet para: '${COR_DESTAQUE}$MODELO${COR_INFO}'...${RESET}"
echo -e "Aguarde...\n"

# Captura o Ano, Mês e Dia atuais para comparação
HOJE_Y=$(date +%Y)
HOJE_M=$(date +%m)
HOJE_D=$(date +%d)

# Faz o download do RSS e processa com awk
curl -s "$URL" | awk \
    -v search="$MODELO" \
    -v h_y="$HOJE_Y" \
    -v h_m="$HOJE_M" \
    -v h_d="$HOJE_D" '
BEGIN {
    IGNORECASE = 1
    encontrados = 0
    
    # Data de hoje para comparação numérica (YYYYMMDD)
    c_int = (h_y + 0) * 10000 + (h_m + 0) * 100 + (h_d + 0)
    
    # Cores ANSI
    C_RESET  = "\033[0m"
    C_BOLD   = "\033[1m"
    C_CYAN   = "\033[1;36m"
    C_YELLOW = "\033[1;33m"
    C_GREEN  = "\033[1;32m"
    C_RED    = "\033[1;31m"
    C_ORANGE = "\033[38;5;208m"
}

/<item>/ {
    in_item = 1; title = ""; desc = ""; next
}

/<\/item>/ {
    if (in_item && title ~ search) {
        encontrados++
        print C_CYAN "======================================================" C_RESET
        print "📌 " C_BOLD C_YELLOW "Modelo: " C_CYAN title C_RESET
        print C_CYAN "======================================================" C_RESET
        
        # Extração e limpeza da descrição
        gsub(/.*<description>/, "", desc)
        gsub(/<\/description>.*/, "", desc)
        gsub(/&lt;/, "<", desc)
        gsub(/&gt;/, ">", desc)
        
        # Tradução dos campos
        gsub(/Category:/, "Categoria:", desc)
        gsub(/End of Order:/, "Fim das Vendas (EOO):", desc)
        gsub(/Last Service Extension:/, "Última Renovação (LSED):", desc)
        gsub(/End of Support:/, "Fim do Suporte (EOS):", desc)
        
        n = split(desc, linhas, "<br/>")
        for (i = 1; i <= n; i++) {
            sub(/^[ \t]+/, "", linhas[i])
            sub(/,[ \t]*$/, "", linhas[i])
            
            if (linhas[i] != "") {
                idx = index(linhas[i], ":")
                if (idx > 0) {
                    label = substr(linhas[i], 1, idx)
                    value = substr(linhas[i], idx + 1)
                    sub(/^[ \t]+/, "", value)
                    
                    val_color = C_RESET
                    
                    # Lógica de colorização de datas
                    if (match(value, /[0-9]{4}-[0-9]{2}-[0-9]{2}/)) {
                        date_str = substr(value, RSTART, RLENGTH)
                        split(date_str, d_arr, "-")
                        
                        ty = d_arr[1] + 0; tm = d_arr[2] + 0; td = d_arr[3] + 0
                        t_int = ty * 10000 + tm * 100 + td
                        
                        val_color = C_GREEN
                        if (t_int < c_int) {
                            val_color = C_RED
                        } else {
                            # Cálculo aproximado de proximidade (2 meses)
                            diff_m = (ty - h_y) * 12 + (tm - h_m)
                            if (diff_m < 2 || (diff_m == 2 && td <= h_d)) {
                                val_color = C_ORANGE
                            }
                        }
                    }
                    print "  " C_BOLD label C_RESET " " val_color value C_RESET
                } else {
                    print "  " linhas[i]
                }
            }
        }
        print ""
    }
    in_item = 0
}

in_item && /<title>/ {
    title = $0; gsub(/.*<title>/, "", title); gsub(/<\/title>.*/, "", title)
}

in_item && /<description>/ {
    desc = $0
}

END {
    if (encontrados == 0) {
        print C_RED "❌ Nenhum equipamento encontrado para o termo: " C_RESET C_BOLD search C_RESET
    }
}
'
